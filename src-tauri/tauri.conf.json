{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-2-schema/main/schema.json",
  "productName": "probe-gui",
  "version": "0.1.0",
  "identifier": "com.probe-gui.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Probe GUI",
        "width": 1000,
        "height": 700,
        "minWidth": 480,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
